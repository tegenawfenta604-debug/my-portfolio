# Django
SECRET_KEY=django-insecure-change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (SQLite for dev; fill PostgreSQL fields for production)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
